# Copy to ".env" in this folder (Vite loads it automatically).
# Base URL of the Express API (no trailing slash).
VITE_API_URL=http://localhost:4000

# Example when other devices on the LAN use your PC as the server:
# VITE_API_URL=http://192.168.1.2:4000
#
# If VITE_API_URL uses a LAN IP but you open the UI at http://localhost:5173, the app
# automatically uses http://localhost:<api-port> for API + Socket.IO (see src/apiBase.js).

# WebRTC ICE servers (JSON array of RTCIceServer). Default STUN is used if unset or invalid.
# VITE_WEBRTC_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"}]
